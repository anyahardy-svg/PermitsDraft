# Supabase Configuration
# Get these values from your Supabase project settings:
# https://app.supabase.com -> Project Settings -> API
# Copy from .env (do not edit this file)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Required for scripts/upload-email-logos.js (service role key from Supabase -> Project Settings -> API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Brevo Email Service
# Get from: https://dashboard.brevo.com/account/api/keys
VITE_BREVO_API_KEY=your-brevo-api-key-here

# Scheduled accreditation invitation reminders (Vercel Cron)
# Generate a long random string and set the same value in Vercel project env vars
CRON_SECRET=your-cron-secret-here
# Max companies reminded per day (default 200; hard-capped at 300 in code)
REMINDER_BATCH_SIZE=200
