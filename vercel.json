{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "EXPO_NO_CLIENT_ENV_VARS": "1"
  },
  "rewrites": [
    {
      "source": "/sign-in-contractor",
      "destination": "/index.html"
    },
    {
      "source": "/sign-in-contractor/",
      "destination": "/index.html"
    },
    {
      "source": "/sign-in-visitor",
      "destination": "/index.html"
    },
    {
      "source": "/sign-in-visitor/",
      "destination": "/index.html"
    },
    {
      "source": "/sign-out",
      "destination": "/index.html"
    },
    {
      "source": "/sign-out/",
      "destination": "/index.html"
    },
    {
      "source": "/permits",
      "destination": "/index.html"
    },
    {
      "source": "/permits/",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}

